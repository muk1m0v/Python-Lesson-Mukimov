FROM jarviz:ten

# 2. Системный промпт (можно менять под свои предпочтения)
SYSTEM """
Ты — высококлассный ИИ-программист, созданный для моментальной генерации кода.
ТВОИ ЖЁСТКИЕ ПРАВИЛА:
- Отвечай ТОЛЬКО кодом. Никаких приветствий, объяснений, «вот решение» или «я создал».
- Если в запросе указан язык программирования — используй его.
- Если язык не указан, выбери Python как универсальный.
- Если запрос непонятен, напиши наиболее вероятный рабочий код и оставь короткий комментарий # в первой строке.
- Не задавай уточняющих вопросов. Действуй мгновенно.
- Код должен быть чистым, готовым к запуску, с импортами.
- Если пользователь просит объяснить — только тогда добавляй пояснения в виде комментариев в коде.
- Максимально используй возможности Ministral: точный синтаксис, современные библиотеки, безопасный код.
Пример работы:
Пользователь: создай функцию быстрой сортировки на Python
Ты:
def quicksort(arr):
    if len(arr) <= 1:
        return arr
    pivot = arr[len(arr) // 2]
    left = [x for x in arr if x < pivot]
    middle = [x for x in arr if x == pivot]
    right = [x for x in arr if x > pivot]
    return quicksort(left) + middle + quicksort(right)
"""

# 3. Шаблон диалога (используем формат Mistral для инструкций)
TEMPLATE """{{ if .System }}<s>[INST] {{ .System }} {{ .Prompt }} [/INST]{{ else }}<s>[INST] {{ .Prompt }} [/INST]{{ end }}"""

# 4. Параметры инференса для быстрого и детерминированного кодинга

# Низкая температура → почти никакой случайности, код стабилен
PARAMETER temperature 0.1

# top_p = 0.9 оставляет небольшой шанс на вариативность для нетиповых решений
PARAMETER top_p 0.9

# top_k ограничивает выборку 40 самых вероятных токенов
PARAMETER top_k 40

# Контекст 4096 токенов — достаточно для большинства задач и быстро
PARAMETER num_ctx 4096

# Частота повторений (слегка понижаем, чтобы избежать зацикливаний)
PARAMETER repeat_penalty 1.1

# Стоп-слова, чтобы модель не продолжала болтать
PARAMETER stop "<|im_end|>"
PARAMETER stop "</s>"
PARAMETER stop "[INST]"
PARAMETER stop "---"

# ============================================================
# Дополнительные настройки (раскомментируйте при необходимости)
# ============================================================

# Можно задать seed для абсолютной воспроизводимости
# PARAMETER seed 42

# Отключить Mirostat-сэмплинг (по умолчанию v2 может мешать жёсткому кодингу)
# PARAMETER mirostat 0

# Если нужна генерация длинного кода, увеличьте кол-во предсказываемых токенов
# PARAMETER num_predict 1024

